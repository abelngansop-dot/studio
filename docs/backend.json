{
  "entities": {
    "Shop": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shop",
      "type": "object",
      "description": "Represents a single vendor's shop on the marketplace.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Shop."
        },
        "name": {
          "type": "string",
          "description": "The public name of the shop."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns the shop."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL for the shop's logo or profile image."
        },
        "services": {
          "type": "array",
          "description": "The types of services offered by the shop.",
          "items": { "type": "string" }
        },
        "country": {
          "type": "string",
          "description": "The country where the shop is located."
        },
        "city": {
          "type": "string",
          "description": "The city where the shop is located."
        },
        "phone": {
          "type": "string",
          "description": "The contact phone number for the shop."
        },
        "subscriptionPlan": {
          "type": "string",
          "description": "The current subscription plan for the shop.",
          "enum": ["basic", "premium", "pro", "none"]
        },
        "status": {
          "type": "string",
          "description": "The status of the shop.",
          "enum": ["active", "suspended", "pending_setup"]
        },
        "averageRating": {
          "type": "number",
          "description": "The average rating of the shop based on customer reviews."
        },
        "reviewCount": {
          "type": "number",
          "description": "The total number of reviews for the shop."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the shop was created."
        }
      },
      "required": ["name", "ownerId", "subscriptionPlan", "status", "createdAt", "services", "country", "city"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Inoublevents application.",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier from Firebase Auth." },
        "email": { "type": "string", "description": "The email address of the user.", "format": "email" },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "photoURL": { "type": "string", "description": "URL of the user's profile picture.", "format": "uri" },
        "phone": { "type": "string", "description": "The user's phone number." },
        "gender": { "type": "string", "description": "The gender of the user.", "enum": ["homme", "femme"] },
        "role": { "type": "string", "description": "The role of the user.", "enum": ["client", "shop_admin", "admin", "superadmin"] },
        "shopId": { "type": "string", "description": "The ID of the shop this user owns or manages. Only applicable for shop_admin role." },
        "createdAt": { "type": "string", "description": "The date and time the user was created.", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "ShopAdmin": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shop Admin",
      "type": "object",
      "description": "Represents a user's admin rights over a shop.",
       "properties": {
        "userId": { "type": "string", "description": "The UID of the admin user." },
        "addedAt": { "type": "string", "format": "date-time", "description": "The date the user was made an admin." }
      },
      "required": ["userId", "addedAt"]
    },
    "Booking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Booking",
      "type": "object",
      "description": "Represents a booking request made by a user for event services from a specific shop.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Booking entity." },
        "shopId": { "type": "string", "description": "The ID of the shop providing the service." },
        "userId": { "type": "string", "description": "Reference to the User who made the booking." },
        "eventType": { "type": "string", "description": "The type of event." },
        "services": { "type": "array", "description": "A list of requested service names.", "items": { "type": "string" } },
        "country": { "type": "string", "description": "The country of the event." },
        "city": { "type": "string", "description": "The city of the event." },
        "date": { "type": "string", "description": "The date of the event.", "format": "date-time" },
        "contactInfo": { "type": "object", "properties": { "email": { "type": "string" }, "phone": { "type": "string" } }, "required": ["phone"] },
        "status": { "type": "string", "description": "The status of the booking (e.g., pending, confirmed, cancelled).", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "description": "The date and time the booking was created.", "format": "date-time" },
        "requestDetails": { "type": "string", "description": "Specific details for an 'other' type event request." }
      },
      "required": ["shopId", "userId", "eventType", "services", "country", "city", "date", "status", "createdAt", "contactInfo"]
    },
    "Service": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Service",
      "type": "object",
      "description": "Represents a service offered for events by a specific shop.",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string", "description": "The ID of the shop providing the service." },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "rating": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string", "format": "uri" }
      },
      "required": ["shopId", "name", "description", "icon"]
    },
    "EventType": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EventType",
      "type": "object",
      "description": "Represents a type of event that can be booked within a shop.",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string", "description": "The ID of the shop this event type belongs to." },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string", "format": "uri" }
      },
      "required": ["shopId", "name", "icon"]
    },
    "Review": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Review",
        "type": "object",
        "description": "Represents a review for a specific shop.",
        "properties": {
            "shopId": { "type": "string", "description": "The ID of the shop being reviewed." },
            "userId": { "type": "string" },
            "displayName": { "type": "string" },
            "rating": { "type": "number" },
            "comment": { "type": "string" },
            "status": { "enum": ["pending", "approved", "rejected"] },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["shopId", "userId", "displayName", "rating", "comment", "status", "createdAt"]
    },
    "GalleryImage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Gallery Image",
      "type": "object",
      "description": "Represents an image in a shop's gallery.",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string", "description": "The ID of the shop this image belongs to." },
        "imageUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "imageHint": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "imageUrl", "description", "createdAt"]
    },
    "Subscription": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Subscription",
      "type": "object",
      "description": "Represents a subscription for a shop.",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "plan": { "enum": ["basic", "premium", "pro"] },
        "status": { "enum": ["active", "cancelled", "past_due"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "renewsAt": { "type": "string", "format": "date-time" },
        "stripeSubscriptionId": { "type": "string" }
      },
      "required": ["shopId", "plan", "status", "startDate"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/entities/User" },
          "description": "Stores global user profiles and roles."
        }
      },
      {
        "path": "/shops/{shopId}",
        "definition": {
          "schema": { "$ref": "#/entities/Shop" },
          "description": "Stores all shops in the marketplace."
        }
      },
      {
        "path": "/shops/{shopId}/services/{serviceId}",
        "definition": {
          "schema": { "$ref": "#/entities/Service" },
          "description": "Services offered by this shop."
        }
      },
      {
        "path": "/shops/{shopId}/bookings/{bookingId}",
        "definition": {
          "schema": { "$ref": "#/entities/Booking" },
          "description": "Bookings made for this shop's services."
        }
      },
      {
        "path": "/shops/{shopId}/eventTypes/{eventTypeId}",
        "definition": {
          "schema": { "$ref": "#/entities/EventType" },
          "description": "Event types managed by this shop."
        }
      },
      {
        "path": "/shops/{shopId}/reviews/{reviewId}",
        "definition": {
          "schema": { "$ref": "#/entities/Review" },
          "description": "Reviews for this shop."
        }
      },
      {
        "path": "/shops/{shopId}/gallery/{galleryImageId}",
        "definition": {
          "schema": { "$ref": "#/entities/GalleryImage" },
          "description": "Gallery images for this shop."
        }
      },
      {
        "path": "/shops/{shopId}/subscriptions/{subscriptionId}",
        "definition": {
          "schema": { "$ref": "#/entities/Subscription" },
          "description": "Subscription history for this shop."
        }
      },
      {
        "path": "/shops/{shopId}/admins/{userId}",
        "definition": {
          "schema": { "$ref": "#/entities/ShopAdmin" },
          "description": "A list of users with admin permissions for this shop."
        }
      }
    ]
  }
}
